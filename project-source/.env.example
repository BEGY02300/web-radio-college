# ╔═══════════════════════════════════════════════════════════════════╗
# ║  CLÉS API - Copiez ce fichier en .env et remplissez vos valeurs    ║
# ╠═══════════════════════════════════════════════════════════════════╣
# ║  $ cp .env.example .env                                            ║
# ║  Puis éditez .env avec vos vraies clés.                           ║
# ║  ⚠️  Ne commitez JAMAIS le fichier .env dans Git.                  ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ─── FIREBASE (Authentication) ─────────────────────────────────────
# Console Firebase → Paramètres du projet → Vos applications → Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── SUPABASE (Commentaires) ───────────────────────────────────────
# Dashboard Supabase → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
